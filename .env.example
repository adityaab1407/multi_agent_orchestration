# NewsForge environment configuration
# Copy this file to .env and fill in your keys.

# --- LLM (Groq) ---
# Groq API — create a DEDICATED key per project
# at console.groq.com/keys
# Never reuse keys across projects — keeps
# rate limits and usage tracking isolated
GROQ_API_KEY=your_newsforge_dedicated_groq_key

# Model routing — two pools for rate dispersion
# Pool A: Reasoning agents (Planner, Analysis)
GROQ_REASONING_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Pool B: Execution + Evaluation agents (Writer, Critic, Judge)
GROQ_EXECUTION_MODEL=llama-3.1-8b-instant
GROQ_JUDGE_MODEL=llama-3.1-8b-instant

# --- Embeddings (local, no API key needed) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- Vector Store (Qdrant, local folder) ---
QDRANT_PATH=./qdrant_storage
COLLECTION_NAME=multi_agent

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- Retrieval ---
TOP_K=5

# --- Search (Tavily) ---
TAVILY_API_KEY=your-tavily-api-key-here
SEARCH_RESULTS_PER_QUERY=5

# --- Observability (Langfuse) ---
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Pipeline tuning ---
MAX_REACT_ITERATIONS=3
PLANNING_QUALITY_THRESHOLD=0.7

# --- Storage ---
SQLITE_DB_PATH=data/newsforge_checkpoints.db

# --- API Authentication (optional) ---
# Leave empty to disable authentication (development mode)
# Set a secret value to require X-API-Key header on all endpoints
API_KEY=

# --- AWS (optional — Publisher Agent uses S3 + DynamoDB when all vars are set) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
DYNAMODB_TABLE=
