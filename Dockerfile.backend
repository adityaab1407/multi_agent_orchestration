# ── Dockerfile.backend ─────────────────────────────────────────────────
# FastAPI backend for NewsForge multi-agent research system
# ───────────────────────────────────────────────────────────────────────
FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Install system deps needed by Playwright Chromium and lxml
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libxml2-dev \
    libxslt-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps first (better layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright + Chromium — || true means build continues if this
# fails (e.g. on a slim image missing system libs).
RUN pip install playwright || true
RUN playwright install chromium || true
RUN playwright install-deps chromium || true

# Copy project
COPY . .

# Create data dir for SQLite checkpointer
RUN mkdir -p /app/data

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/health')"

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8080"]
